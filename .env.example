# --- LLM and data API ports --------------------------------------------------
# The default llm.provider is `openai`, so OPENAI_API_KEY powers every agent.
# Leave any key empty to run the affected provider/data path on its fallback.
OPENAI_API_KEY=            # default shared LLM backbone; also PaperQA2's default backend
GEMINI_API_KEY=            # quant_reader (Gemini; GOOGLE_API_KEY also accepted)
ANTHROPIC_API_KEY=         # quant_coder (Claude; needs `pip install anthropic`)
XAI_API_KEY=               # quant_scout (Grok; GROK_API_KEY also accepted)
DEEPSEEK_API_KEY=          # quant_bench (DeepSeek)
OPENALEX_API_KEY=          # journal metadata + conference abstract enrichment

# --- Workflow defaults -------------------------------------------------------
ARXIV_QUERY=quantitative finance
DATA_DIR=./data
REPORT_DIR=./reports
DEFAULT_MAX_PAPERS=5
